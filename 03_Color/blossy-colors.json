    "muted":     { "value": "#737373", "type": "color" },
    "faint":     { "value": "#a3a3a3", "type": "color" }
  },
  "landing": {
    "cream":  { "value": "#FAF4EC", "type": "color" },
    "peach":  { "value": "#F5C9A8", "type": "color" },
