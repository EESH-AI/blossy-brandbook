{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "Blossy",
  "description": "Colour tokens for blossy.ai. Single warm theme: cream paper, terracotta accent, pastel atmosphere. Source of truth: src/app/globals.css",
  "brand": {
    "orange":      { "value": "#E96A2E", "type": "color", "description": "The brand terracotta — the one accent" },
    "orangeDeep":  { "value": "#d85a1d", "type": "color", "description": "Deep end of the brand gradient" },
    "orangeLift":  { "value": "#f0824c", "type": "color", "description": "Light end — gradients only" }
  },
  "logo": {
    "coral":       { "value": "#FF9A6B", "type": "color", "description": "Mark gradient stop 0" },
    "magenta":     { "value": "#F2497E", "type": "color", "description": "Mark gradient stop 1" },
    "wordmarkInk": { "value": "#241B22", "type": "color", "description": "Plum-black wordmark on light grounds" },
    "wordmarkOnDark": { "value": "#FFFFFF", "type": "color", "description": "Wordmark on dark/colour grounds" }
  },
  "surface": {
    "background": { "value": "#faf5ed", "type": "color", "description": "Cream paper — app ground" },
    "surface":    { "value": "#fffdf8", "type": "color", "description": "Warm white — cards" },
    "secondary":  { "value": "#f6efe1", "type": "color", "description": "Warm sand" },
    "hover":      { "value": "#f0e8d8", "type": "color" }
  },
  "border": {
