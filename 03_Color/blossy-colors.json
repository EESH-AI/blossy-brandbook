    "brand90": { "value": "linear-gradient(90deg, #E96A2E, #f0824c)", "type": "gradient" },
    "logo":    { "value": "linear-gradient(135deg, #FF9A6B, #F2497E)", "type": "gradient" },
    "hero":    { "value": "linear-gradient(180deg, transparent 0%, transparent 42%, #F5C9A8 72%, #F9B1B1 100%)", "type": "gradient" },
