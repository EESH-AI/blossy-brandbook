    "warning": {
      "base":    { "value": "#b45309", "type": "color" },
      "strong":  { "value": "#92400e", "type": "color" },
      "surface": { "value": "#fffbeb", "type": "color" },
      "line":    { "value": "#fde68a", "type": "color" }
    },
    "success": {
      "base":    { "value": "#059669", "type": "color" },
